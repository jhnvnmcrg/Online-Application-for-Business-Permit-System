# ============================================
# EMAIL NOTIFICATION CONFIGURATION (OPTIONAL)
# ============================================
# Enable or disable email notifications
# Set to "true" to enable automatic emails to business owners
# Set to "false" to disable (system will work normally without emails)
EMAIL_ENABLED=true

# Email service provider (gmail, outlook, yahoo, etc.)
EMAIL_SERVICE=gmail

# Sender email address (YOUR system's email)
# This email will appear as the sender of all notifications
# For Gmail: Must use App Password, not regular password
#   1. Enable 2-Factor Authentication on your Google Account
#   2. Go to https://myaccount.google.com/apppasswords
#   3. Generate an App Password (16 characters)
#   4. Use that password below
EMAIL_USER=johnivanmacaraeg01@gmail.com

# Email password or App Password
# IMPORTANT: For Gmail, this must be an App Password, not your regular password
EMAIL_PASSWORD=oabspass123

# ============================================
# HOW IT WORKS:
# ============================================
# When EMAIL_ENABLED=true:
#   - Business owners receive automatic email notifications for:
#     * Application submitted
#     * Payment required
#     * Payment verified/rejected
#     * Application approved/rejected
#   - Emails are sent FROM: EMAIL_USER (your system's email)
#   - Emails are sent TO: Business owner's email (from database)
#
# When EMAIL_ENABLED=false:
#   - System works normally
#   - No emails are sent
#   - No errors occur
#   - Perfect for development/testing
#
# TROUBLESHOOTING:
#   - "Invalid login" error? Use App Password, not regular password
#   - "Connection timeout"? Check your internet connection
#   - Email not sending? Check EMAIL_USER and EMAIL_PASSWORD are correct
#   - Server logs will show email status (✓ sent, ✗ failed, ℹ disabled)
